rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // True when the requester is the linked coach for `athleteUid`.
    // Reads the athlete's coachId field, so the rule itself works against
    // any user doc whose coachId == requester.uid.
    function isCoachOf(athleteUid) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(athleteUid))
        && get(/databases/$(database)/documents/users/$(athleteUid)).data.coachId == request.auth.uid;
    }

    // True when the requester is the athlete's linked coach AND the athlete
    // granted at least 'comment'. Default permission (missing field) is
    // 'view', which fails this check - so a view-only coach cannot suggest.
    function coachHasComment(athleteUid) {
      return isCoachOf(athleteUid)
        && get(/databases/$(database)/documents/users/$(athleteUid))
             .data.get('coachPermission', 'view') in ['comment', 'edit'];
    }

    match /users/{uid} {
      // Read access:
      //   1. The owner reads their own doc.
      //   2. A coach reads any athlete doc whose coachId points to them.
      //   3. Any authenticated user reads coach profiles. (Needed so
      //      athletes can look their coach up by email at signup time.
      //      Coach profiles are effectively public to logged-in users —
      //      athlete docs remain private to owner+coach.)
      allow read: if request.auth != null && (
        isOwner(uid)
        || resource.data.coachId == request.auth.uid
        || resource.data.role == 'coach'
      );

      // Athletes/coaches can only write their own profile.
      allow write: if isOwner(uid);

      match /skis/{skiId} {
        allow read: if isOwner(uid) || isCoachOf(uid);
        allow write: if isOwner(uid);
      }
      match /waxLogs/{logId} {
        allow read: if isOwner(uid) || isCoachOf(uid);
        allow write: if isOwner(uid);
      }
      match /testLogs/{logId} {
        allow read: if isOwner(uid) || isCoachOf(uid);
        allow write: if isOwner(uid);
      }
      // Wax Truck tests are the coach's own working data — owner-only.
      match /waxTests/{testId} {
        allow read, write: if isOwner(uid);
      }
    }

    // Coach acceptance — top-level collection so the coach can query
    // "requests for me" without touching the athlete's user doc tree.
    match /coachRequests/{requestId} {
      // Either party in the request can read it.
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.athleteUid
            || request.auth.uid == resource.data.coachUid);

      // Athletes create new requests targeting a coach. They must be
      // the one signing the request and the doc must start as 'pending'.
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.athleteUid
        && request.resource.data.status == 'pending';

      // Two state transitions are allowed via update:
      //  - The athlete cancels their own pending request → 'cancelled'.
      //  - The coach accepts or declines a pending request →
      //    'accepted' / 'declined'.
      // Once a request is in a terminal state ('accepted', 'declined',
      // 'cancelled', 'ended'), it can also transition 'accepted' → 'ended'
      // by either party (mutual unlink).
      allow update: if request.auth != null
        && (
          (request.auth.uid == resource.data.athleteUid
            && resource.data.status == 'pending'
            && request.resource.data.status == 'cancelled')
          ||
          (request.auth.uid == resource.data.coachUid
            && resource.data.status == 'pending'
            && (request.resource.data.status == 'accepted'
                || request.resource.data.status == 'declined'))
          ||
          ((request.auth.uid == resource.data.athleteUid
            || request.auth.uid == resource.data.coachUid)
            && resource.data.status == 'accepted'
            && request.resource.data.status == 'ended')
        );

      // No client-side delete — requests are an audit log.
      allow delete: if false;
    }

    // In-app messages — coach → athlete only. The coach must currently
    // be the athlete's linked coach at create time (rules check
    // users/{athleteUid}.coachId == request.auth.uid).
    match /messages/{messageId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);

      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.fromUid
        && exists(/databases/$(database)/documents/users/$(request.resource.data.toUid))
        && get(/databases/$(database)/documents/users/$(request.resource.data.toUid)).data.coachId == request.auth.uid;

      // Athlete can mark a message read; nothing else.
      allow update: if request.auth != null
        && request.auth.uid == resource.data.toUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'updatedAt']);

      allow delete: if false;
    }

    // Coach -> athlete invites: the coach's PRIVATE tracking list of who
    // they invited and the status. There is deliberately NO public / athlete
    // read here, so invite tokens cannot be enumerated. Redemption does NOT
    // happen via a token lookup in this collection - the athlete connects
    // through the existing athlete-initiated coachRequests flow (entering the
    // coach's email). This doc is purely the coach's record.
    match /athleteInvites/{inviteId} {
      // Only the owning coach reads / lists their invites.
      allow read: if request.auth != null
        && request.auth.uid == resource.data.coachUid;

      // A coach creates an invite they own; it must start 'pending'.
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.coachUid
        && request.resource.data.status == 'pending';

      // The owning coach can update (e.g. revoke) their own invite.
      allow update: if request.auth != null
        && request.auth.uid == resource.data.coachUid;

      // Keep an audit trail - no client delete.
      allow delete: if false;
    }

    // Coach -> athlete fleet suggestions. A coach with comment (or edit)
    // permission proposes changes; the ATHLETE accepts (applying the change
    // via their own owner-write on the ski/wax/test doc) or rejects. The coach
    // never writes the athlete's data directly - view/comment do not loosen
    // the owner-only write rule on skis/waxLogs/testLogs.
    match /fleetSuggestions/{suggestionId} {
      // Both parties read a suggestion they're part of.
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.athleteUid
            || request.auth.uid == resource.data.coachUid);

      // Coach creates a PENDING suggestion for an athlete who granted
      // comment|edit, for a valid target type.
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.coachUid
        && request.resource.data.status == 'pending'
        && request.resource.data.targetType in ['ski', 'waxLog', 'testLog']
        && coachHasComment(request.resource.data.athleteUid);

      // The athlete (and only the athlete) accepts/rejects their own
      // suggestion. coachUid + athleteUid + target are immutable on update.
      allow update: if request.auth != null
        && request.auth.uid == resource.data.athleteUid
        && request.resource.data.coachUid == resource.data.coachUid
        && request.resource.data.athleteUid == resource.data.athleteUid
        && request.resource.data.targetType == resource.data.targetType
        && request.resource.data.targetId == resource.data.targetId
        && request.resource.data.status in ['accepted', 'rejected'];

      // Keep an audit trail - no client delete.
      allow delete: if false;
    }

    // Marketing email signups from the public website. Anyone (signed in
    // or not) can submit one, but nobody can read, update, or delete them
    // from the client — they're an internal lead list. We require the doc
    // to carry an `email` and a server `createdAt`, and forbid anything
    // larger than the known shape.
    match /marketingSignups/{signupId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        && request.resource.data.keys().hasOnly(['email', 'source', 'role', 'createdAt']);
      allow read, update, delete: if false;
    }
  }
}
