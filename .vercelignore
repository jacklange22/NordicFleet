# Exclude heavy directories that exceed Vercel's 15k-file upload limit.
# Keep apps/mobile/package.json so the workspace tree is intact for
# `npm install` at the monorepo root.

apps/mobile/ios/
apps/mobile/android/
apps/mobile/Pods/
apps/mobile/vendor/
apps/mobile/.expo/
apps/mobile/.bundle/

# Build artifacts + caches
**/node_modules/
**/.next/
**/out/
**/build/

# Local env files (Vercel project env vars supply these)
**/.env.local

# Verification artifacts
verification-screenshots/
scripts/verify-*.log

# IDE / OS
.DS_Store
.idea/
.vscode/
